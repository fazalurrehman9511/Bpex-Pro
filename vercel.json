{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.bpexpro.com/api/:path*"
    },
    {
      "source": "/bpexch",
      "destination": "https://api.bpexpro.com/bpexch"
    },
    {
      "source": "/bpexch/:path*",
      "destination": "https://api.bpexpro.com/bpexch/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://api.bpexpro.com/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
