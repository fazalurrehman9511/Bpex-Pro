NODE_ENV=production
PORT=3001
ADMIN_USERNAME=superadmin
ADMIN_PASSWORD=change-me-to-a-long-secure-password
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
DATABASE_PATH=./data/flowexch.db
UPLOADS_DIR=./uploads
# Absolute or relative to server/ — where Vite build output lives
# DIST_DIR=../dist
CORS_ORIGIN=https://bpexpro.com,https://www.bpexpro.com
# Allow Vercel preview/prod frontends (set 0 to disable)
# CORS_ALLOW_VERCEL=1
BPEXCH_SYNC_SECRET=change-me-to-a-long-random-sync-secret
# Internal URL used by /bpexch proxy to call this same API (verify + sync)
API_BASE_URL=http://127.0.0.1:3001
# Set to 0 only if nginx/Apache already proxies /bpexch/
ENABLE_BPEXCH_PROXY=1
# Vercel+Hetzner split: do not serve SPA from Node (frontend on Vercel)
# SERVE_FRONTEND=0
# BIND_HOST=127.0.0.1
EMBED_BRAND_NAME=BPEXCH

# Optional — BPEXCH account used to pull live markets for the public homepage
BPEXCH_BASE_URL=https://bpexch.xyz
BPEXCH_LIVE_USERNAME=
BPEXCH_LIVE_PASSWORD=
BPEXCH_LIVE_POLL_MS=8000

# Master/Admin account that can Create User on BPEXCH (for public self-register)
# Do NOT use a Bettor account here — Bettors cannot create downline users.
BPEXCH_AGENT_USERNAME=
BPEXCH_AGENT_PASSWORD=

# Optional — residential / ISP proxy so BPEXCH Cloudflare allows server requests
# Example: http://username:password@proxy-host:8080
# BPEXCH_HTTP_PROXY=
