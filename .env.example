# WhatsApp numbers per country (no + sign, include country code)
VITE_WHATSAPP_PK=923001234567
VITE_WHATSAPP_AE=971501234567
VITE_WHATSAPP_SA=966501234567
VITE_WHATSAPP_GB=447700900123
VITE_WHATSAPP_BD=8801712345678
VITE_WHATSAPP_IN=919876543210

# Public site domain
VITE_SITE_DOMAIN=bpexpro.com
VITE_SITE_URL=https://bpexpro.com

# BPEXCH embed — proxy keeps bpexch.xyz hidden (your URL shows /login)
VITE_BPEXCH_USE_PROXY=true
VITE_BPEXCH_BASE_URL=https://bpexch.xyz

# Your name inside embedded dashboard/login — text only, BPEXCH colors unchanged
VITE_EMBED_BRAND_NAME=BPEXCH

# Deposit receiving accounts (shown in deposit form)
VITE_JAZZCASH_ACCOUNT_TITLE=BpxPro Agent
VITE_JAZZCASH_ACCOUNT_NUMBER=03001234567
VITE_EASYPAISA_ACCOUNT_TITLE=BpxPro Agent
VITE_EASYPAISA_ACCOUNT_NUMBER=03451234567
VITE_BANK_ACCOUNT_TITLE=BpxPro (Pvt) Ltd
VITE_BANK_ACCOUNT_NUMBER=12345678901234
VITE_BANK_NAME=HBL — Main Branch

# API backend — leave EMPTY when using Vercel rewrites to api.bpexpro.com (recommended)
# Only set if calling API on another origin without rewrites, e.g.:
# VITE_API_URL=https://api.bpexpro.com
# VITE_API_URL=

# Capacitor native API — production HTTPS backend (same as site or api subdomain)
VITE_NATIVE_API_URL=https://bpexpro.com

# Must match server/.env BPEXCH_SYNC_SECRET (Vite dev proxy user sync)
BPEXCH_SYNC_SECRET=change-me-to-a-long-random-sync-secret

# Android APK — put real .apk in public/app/ then set:
# VITE_ANDROID_APK_URL=/app/flowexch.apk
# VITE_ANDROID_APP_VERSION=1.0.0
